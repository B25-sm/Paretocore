# Copy to .env.local for local dev (`vercel dev`), or add these in your
# Vercel project's Settings → Environment Variables for production.

# Required — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Required only when "Fetch live sources" is on — https://app.tavily.com
TAVILY_API_KEY=tvly-your_key_here
